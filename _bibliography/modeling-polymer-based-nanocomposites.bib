@article{ozisik_nmr_2005,
  title = {{{NMR}} relaxation and pulsed-gradient diffusion study of polyethylene nanocomposites},
  volume = {123},
  url = {http://scitation.aip.org/content/aip/journal/jcp/123/13/10.1063/1.2038890},
  abstract = {We performed pulsed-gradient spin-echo nuclear-magnetic-resonance

NMR

experiments on zinc
oxide filled polyethylene. The molecular weights of the polyethylene samples ranged between 808
and 33 000 g/mol, and four different zinc oxide samples were used: 27-, 33-, 51-, and
2500-nm-diameter particles. The results of these experiments showed that the diffusion coefficients
of the polyethylene chains did not change with nanofiller content, but a drastic change is observed
in the NMR relaxation spectrum in spin-spin-relaxation experiments. At fixed zinc oxide content
and polyethylene molecular weight
(close to entanglement)
, the system with the smallest zinc oxide
showed the most rigid environment. At high polyethylene molecular weights, this effect was still
observable but the difference between the three investigated systems was very small, suggesting that
the system was dominated by entanglements.},
  timestamp = {2016-02-07T03:59:01Z},
  number = {13},
  journaltitle = {The Journal of chemical physics},
  shortjournal = {J. Chem. Phys.},
  author = {Ozisik, R. and Zheng, J. and Dionne, P. J. and Picu, Catalin R. and Von Meerwall, E. D.},
  urldate = {2016-01-24},
  date = {2005},
  pages = {134901},
  file = {Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/6Q6SWQQG/1.html:}
}

