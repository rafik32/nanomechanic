  urldate = {2016-01-25},
  date = {2005-09-01},
  pages = {2114--2121},
  keywords = {Atomic force microscopy,Nanorods,Nanostructures,Semiconductor growth,Thin films},
  file = {Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/25QKU9W4/Singh et al. - 2005 - Physical properties of nanostructures grown by obl.pdf:application/pdf;Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/CQ28XBA7/1.html:}
}

@article{soare_fluid_2006,
  title = {Fluid {{Transport}} through {{Nanochannels}} using {{Nanoelectromechanical Actuators}}},
  volume = {17},
  issn = {1045-389X, 1530-8138},
  url = {http://jim.sagepub.com.libproxy.rpi.edu/content/17/3/231},
  doi = {10.1177/1045389X06056861},
  abstract = {The article presents the basic principle of a nanodevice used to transport fluids through nanochannels. The nanochannel is defined by two parallel plates, one (or both of them) being covered by active thin films. The films deform under the action of an electric current passing in the film through the thickness direction. This leads to a local increase in film thickness, which forms a protrusion that narrows the channel. The propagation of such protrusions along the channel leads to the pumping effect. This motion is produced and controlled electronically. Here we focus on the mechanical actuation device as well as the ensuing coupled fluid and solid mechanics problem. We describe in detail the nature and function of the active films. Then, we provide an answer to the question: given a desired fluid flux, what is the magnitude and spatial distribution of the controlling current one has to supply to the actuators?},
  timestamp = {2016-02-07T04:02:05Z},
  langid = {english},
  number = {3},
  journaltitle = {Journal of Intelligent Material Systems and Structures},
  shortjournal = {Journal of Intelligent Material Systems and Structures},
  author = {Soare, M. A. and Picu, Catalin R. and Tichy, J. and Lu, T.-M. and Wang, G.-C.},
  urldate = {2016-01-25},
  date = {2006-01-03},
  pages = {231--238},
  keywords = {active materials,nanopumps,Nanostructures,NEMS},
  file = {Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/HXAR92IT/231.html:}
}

@article{karabacak_stress_2004,
  title = {Stress reduction in tungsten films using nanostructured compliant layers},
  volume = {96},
  issn = {0021-8979, 1089-7550},
  url = {http://scitation.aip.org.libproxy.rpi.edu/content/aip/journal/jap/96/10/10.1063/1.1803106},
  doi = {10.1063/1.1803106},
  abstract = {The residual stress in thin films is a major limiting factor for obtaining high quality films. We present a strategy for stress reduction in sputter depositedfilms by using a nanostructured compliant layer obtained by the oblique angle deposition technique, sandwiched between the film and the substrate. The technique is all in situ, does not require any lithography steps, and the nanostructured layer is made from the same material as the depositedthin film. By using this approach we were able to reduce stress values by approximately one order of magnitude in sputter depositedtungstenfilms. These lower stress thin films also exhibit stronger adhesion to the substrate, which retards delamination buckling. This technique allows the growth of much thicker films and has enhanced structural stability. A model is developed to explain the stress relief mechanism and the stronger adhesion associated with the presence of the nanostructured compliant layer.},
  timestamp = {2016-01-25T00:02:27Z},
  number = {10},
  journaltitle = {Journal of Applied Physics},
  shortjournal = {J. Appl. Phys.},
  author = {Karabacak, Tansel and Picu, Catalin R. and Senkevich, Jay J. and Wang, Gwo-Ching and Lu, Toh-Ming},
  urldate = {2016-01-25},
  date = {2004-11-15},
  pages = {5740--5746},
  keywords = {Nanorods,Sputter deposition,Thin film growth,Thin films,Thin film structure},
  file = {Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/QD3B3RM8/Karabacak et al. - 2004 - Stress reduction in tungsten films using nanostruc.pdf:application/pdf;Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/RD2HZD5T/1.html:}
}

@article{liu_size_2004,
  title = {Size effect and strain rate sensitivity in benzocyclobutene film},
  volume = {85},
  issn = {0003-6951, 1077-3118},
  url = {http://scitation.aip.org.libproxy.rpi.edu/content/aip/journal/apl/85/15/10.1063/1.1805710},
  doi = {10.1063/1.1805710},
  abstract = {The mechanical properties of benzocyclobutene film are investigated at the nanoscale by nano-indentation using atomic force microscopy(AFM). The force versus indentation depth data were collected with two different AFM tips of radii ∼ 20 and ∼ 380 nm . A strong size effect of the plastic flow stress was observed as the radius of the indenter tip was reduced. More important, the material exhibited pronounced strain rate sensitivity when probed at the nanoscale, while it was rate insensitive at larger scales. These two size effects were quantified by analytic and finite element modeling.},
  timestamp = {2016-02-07T04:02:47Z},
  number = {15},
  journaltitle = {Applied Physics Letters},
  shortjournal = {Appl. Phys. Lett.},
  author = {Liu, D.-L. and Lu, T.-M. and Wang, G.-C. and Picu, Catalin R.},
  urldate = {2016-01-25},
  date = {2004-10-11},
  pages = {3053--3055},
  keywords = {Atomic force microscopes,Atomic force microscopy,Nanomaterials,Plasticity,Stress strain relations},
  file = {Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/GWM8JWV3/1.html:;Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/MIIK69NZ/Liu et al. - 2004 - Size effect and strain rate sensitivity in benzocy.pdf:application/pdf}
}

@article{singh_metalcoated_2004,
  title = {Metal-coated {{Si}} springs: {{Nanoelectromechanical}} actuators},
  volume = {84},
  issn = {0003-6951, 1077-3118},
  url = {http://scitation.aip.org.libproxy.rpi.edu/content/aip/journal/apl/84/18/10.1063/1.1738935},
  doi = {10.1063/1.1738935},
  shorttitle = {Metal-coated {{Si}} springs},
  abstract = {We demonstrated a nanoscale electromechanical actuator operation using an isolated nanoscale spring. The four-turn Si nanosprings were grown using the oblique angle deposition technique with substrate rotation, and were rendered conductive by coating with a 10-nm-thick Co layer using chemical vapor deposition. The electromechanical actuation of a nanospring was performed by passing through a dc current using a conductive atomic force microscope(AFM) tip. The electromagnetic force leads to spring compression, which is measured with the same AFM tip. The spring constant was determined from these measurements and was consistent with that obtained from a finite element analysis.},
  timestamp = {2016-02-07T04:02:27Z},
  number = {18},
  journaltitle = {Applied Physics Letters},
  shortjournal = {Appl. Phys. Lett.},
  author = {Singh, J. P. and Liu, D.-L. and Ye, D.-X. and Picu, Catalin R. and Lu, T.-M. and Wang, G.-C.},
  urldate = {2016-01-25},
  date = {2004-05-03},
  pages = {3657--3659},
  keywords = {Atomic force microscopes,Chemical vapor deposition,Finite element methods,Nanoelectromechanical systems},
  file = {Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/KCCSA9A3/1.html:;Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/SPV6BNXQ/Singh et al. - 2004 - Metal-coated Si springs Nanoelectromechanical act.pdf:application/pdf}
}

@article{liu_mechanics_2003,
  title = {Mechanics of {{Patterned Helical Si Springs}} on {{Si Substrate}}},
  volume = {3},
  doi = {10.1166/jnn.2003.235},
  abstract = {The elastic response, including the spring constant, of individual Si helical-shape submicron springs, was measured using a tip-cantilever assembly attached to a conventional atomic force microscope. The isolated, four-turn Si springs were fabricated using oblique angle deposition with substrate rotation, also known as the glancing angle deposition, on a templated Si substrate. The response of the structures was modeled using finite elements, and it was shown that the conventional formulae for the spring constant required modifications before they could be used for the loading scheme used in the present experiment.},
  timestamp = {2016-02-07T04:02:19Z},
  number = {6},
  journaltitle = {Journal of Nanoscience and Nanotechnology},
  shortjournal = {Journal of Nanoscience and Nanotechnology},
  author = {Liu, D.-L. and Ye, D.-X. and Khan, F. and Tang, F. and Lim, B.-K. and Picu, Catalin R. and Wang, G.-C. and Lu, T.-M.},
  date = {2003-12-01},
  pages = {492--495},
  keywords = {Atomic Force Microscope,Constant,Finite Element,Glancing Angle Deposition,Loading.,Oblique Angle Deposition,Si,Spring,Templated Si},
  file = {IngentaConnect Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/I7GQIQQ4/Liu et al. - 2003 - Mechanics of Patterned Helical Si Springs on Si Su.pdf:application/pdf}
}


