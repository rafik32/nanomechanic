@article{li_shuffleglide_2013,
  title = {Shuffle-glide dislocation transformation in {{Si}}},
  volume = {113},
  issn = {0021-8979, 1089-7550},
  url = {http://scitation.aip.org.libproxy.rpi.edu/content/aip/journal/jap/113/8/10.1063/1.4793635},
  doi = {10.1063/1.4793635},
  abstract = {The transformation of dislocation cores from the shuffle to the glide set of \{111\} glide planes in Si is examined in this work. The transformation is thermally activated and is favored by a resolved shear stress which applies no force on the original perfect shuffle dislocation. A resolved shear stress driving dislocation motion in the glide plane is not observed to promote the transition. The stress-dependent activation energy for the described shuffle-glide transformation mechanism is evaluated using a statistical analysis. It is observed that the transformation is not associated with an intermediate metastable state, as has been previously suggested in the literature.},
  timestamp = {2016-01-25T11:31:49Z},
  number = {8},
  journaltitle = {Journal of Applied Physics},
  shortjournal = {J. Appl. Phys.},
  author = {Li, Z. and Picu, R. C.},
  urldate = {2016-01-25},
  date = {2013-02-28},
  pages = {083519},
  keywords = {Activation energies,Dislocations,Molecular dynamics,Nucleation,Stacking faults},
  file = {Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/3KCZ6C93/Li and Picu - 2013 - Shuffle-glide dislocation transformation in Si.pdf:application/pdf;Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/8ZJN9DK3/1.html:}
}

@article{li_effect_2012,
  title = {Effect of {{Ge}} on dislocation nucleation from surface imperfections in {{Si-Ge}}},
  volume = {112},
  issn = {0021-8979, 1089-7550},
  url = {http://scitation.aip.org.libproxy.rpi.edu/content/aip/journal/jap/112/3/10.1063/1.4745864},
  doi = {10.1063/1.4745864},
  abstract = {Nucleation of dislocation loops from sharp corners playing the role of stress concentrators located on the surface of Si1−xGex strained layers is studied. The surface is of \{100\} type and the concentrator is oriented such as to increase the applied resolved shear stress in one of the \{111\} glide planes. The mean stress in the structure is controlled through the boundary conditions, independent of the Ge concentration. Shuffle dislocations are considered throughout, as appropriate for low temperature-high stress conditions. The effect of Ge atoms located in the glide plane, in the vicinity of the glide plane and at larger distances is studied separately. It is observed that Ge located in the glide plane leads to the reduction of the activation energy for dislocationnucleation. The activation volume in presence of Ge is identical to that in pure Si. Ge located in \{111\} planes three interplanar distances away from the active glide plane has little effect on nucleation parameters. The far-field Ge contributes through the compressive normal stress it produces and leads to a slight reduction of the activation energy for shuffle dislocationnucleation.},
  timestamp = {2016-02-07T04:03:19Z},
  number = {3},
  journaltitle = {Journal of Applied Physics},
  shortjournal = {J. Appl. Phys.},
  author = {Li, Z. and Picu, Catalin R. and Muralidhar, R. and Oldiges, P.},
  urldate = {2016-01-25},
  date = {2012-08-01},
  pages = {034315},
  keywords = {Activation energies,Dislocations,elemental semiconductors,germanium,Nucleation},
  file = {Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/7QCT8JAA/Li et al. - 2012 - Effect of Ge on dislocation nucleation from surfac.pdf:application/pdf;Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/F5IWWNZW/1.html:}
}


