
@article{li_dislocation_2010,
  title = {Dislocation nucleation from interacting surface corners in silicon},
  volume = {108},
  issn = {0021-8979, 1089-7550},
  url = {http://scitation.aip.org.libproxy.rpi.edu/content/aip/journal/jap/108/3/10.1063/1.3471801},
  doi = {10.1063/1.3471801},
  abstract = {The nucleation of dislocations from sharp corners acting as stress concentration sites on a silicon (100) surface is studied by a combination of atomistic and continuum modeling. Ledges of various heights, similar to those found in microelectronic devices, are considered. In this work we focus on the effect of ledge height and of ledge-ledge elastic interaction on the activation energy for dislocationnucleation. The activation energy decreases slightly with increasing the height of the ledge and has a more pronounced, nonmonotonic variation with the distance between stress concentration sites. The effect of introducing a radius of curvature at the root of the ledge is also studied. It is concluded that even a small radius of curvature renders the nucleation process similar to that from a flat surface of same crystallographic orientation.},
  timestamp = {2016-02-07T04:06:36Z},
  number = {3},
  journaltitle = {Journal of Applied Physics},
  shortjournal = {J. Appl. Phys.},
  author = {Li, Z. and Picu, Catalin R.},
  urldate = {2016-01-25},
  date = {2010-08-01},
  pages = {033522},
  keywords = {Activation energies,Boundary value problems,Dislocations,Free surface,Nucleation},
  file = {Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/H88DXB4Z/1.html:;Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/ZC6RIG3P/Li and Picu - 2010 - Dislocation nucleation from interacting surface co.pdf:application/pdf}
}

