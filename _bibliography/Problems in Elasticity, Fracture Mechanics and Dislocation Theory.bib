@article{picu_threedimensional_1997,
  title = {Three-dimensional stress singularities at the tip of a grain triple junction line intersecting the free surface},
  volume = {45},
  issn = {0022-5096},
  url = {http://www.sciencedirect.com/science/article/pii/S0022509697000148},
  doi = {10.1016/S0022-5096(97)00014-8},
  abstract = {The stress singularity at the point of intersection of a grain triple junction line with the free surface has been numerically evaluated in single-phase polycrystals of cubic and hexagonal grains. The angle spanned by the grain boundaries, the orientation of the crystal axes within each grain and the position of the triple junction line with respect to the free surface were taken as variables, and their effect on the singularity exponent γ (defined by σ ∞ rγ−1) determined. In general, the configurations possessing geometrical and material symmetries were associated with stronger singularities and almost all triple junction geometries were characterized by two singularity exponents, each corresponding to the symmetric and the antisymmetric fields. Thus, such a singular point is associated with a fixed mixed mode. Interestingly, the values obtained were somewhat different and stronger when compared with those obtained for the corresponding two-dimensional plane stress and strain configurations.},
  timestamp = {2016-01-25T00:19:31Z},
  number = {9},
  journaltitle = {Journal of the Mechanics and Physics of Solids},
  shortjournal = {Journal of the Mechanics and Physics of Solids},
  author = {Picu, Catalin R. and Gupta, Vijay},
  urldate = {2016-01-25},
  date = {1997-09},
  pages = {1495--1520},
  keywords = {A. crack nucleation,A. microstructures,A. stress concentration,C. finite elements},
  file = {ScienceDirect Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/IEWPNU9K/Picu and Gupta - 1997 - Three-dimensional stress singularities at the tip .pdf:application/pdf;ScienceDirect Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/KPKMG9BX/S0022509697000148.html:}
