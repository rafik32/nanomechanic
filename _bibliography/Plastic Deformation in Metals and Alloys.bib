  pages = {71--75},
  keywords = {Aluminum alloys,Strain ageing,Strain rate sensitivity},
  file = {Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/CQ6NIVS2/S1359646205005440.html:;Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/KB92NTR7/S1359646205005440.html:;ScienceDirect Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/KN7EQI72/S1359646205005440.html:}
