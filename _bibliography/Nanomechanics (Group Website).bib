@article{zandiatashbar_wetting_2011,
  title = {Wetting of nanostructured germanium electrodes by polyethylene oxide},
  volume = {6},
  issn = {17500443},
  url = {http://digital-library.theiet.org/content/journals/10.1049/mnl.2011.0233},
  doi = {10.1049/mnl.2011.0233},
  abstract = {One of the crucial factors that affects the performance of solid electrolyte - lithium-ion batteries is the electrode/electrolyte contact characteristics. Better contact implies greater ion transfer efficiency, leading to improved charge/discharge characteristics, and higher-power densities. In this study, the authors investigate the contact characteristics, viz. wettability, of germanium nanorod thin films initially by water, followed by polyethylene oxide (PEO)/water solution and PEO melt. The authors demonstrate that the electrode surface is hydrophilic, and considerably wettable, as evidenced by the contact angle for PEO/water solution and PEO melt, which are both below 25-. Electron microscopy was used to investigate the electrode/electrolyte contact area, and our results showed that PEO melt efficiently penetrates the inter-rod space, which is a further indication of considerable increase in the contact area.},
  timestamp = {2016-02-07T04:03:54Z},
  langid = {english},
  number = {6},
  journaltitle = {Micro \& Nano Letters},
  shortjournal = {Micro Nano Lett.},
  author = {Zandiatashbar, A. and Gaire, C. and Picu, Catalin R. and Lu, T.-M. and Subramanian, G.},
  urldate = {2016-01-25},
  date = {2011},
  pages = {448},
  keywords = {charge-discharge characteristics,electrodes,electrolyte contact characteristics,electron microscopy,elemental semiconductors,Ge,germanium,germanium nanorod thin films,higher-power densities,hydrophilicity,ion transfer efficiency,lithium,lithium-ion batteries,Nanorods,nanostructured germanium electrodes,PEO melt,PEO-water solution,polyethylene oxide,polymer melts,polymers,secondary cells,semiconductor thin films,solid electrolyte,solid electrolytes,wetting},
  file = {IEEE Xplore Abstract Record:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/2PIGUXVD/articleDetails.html:;IEEE Xplore Abstract Record:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/E3QQAFIV/articleDetails.html:}
