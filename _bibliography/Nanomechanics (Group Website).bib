@article{kroger_polymer_1997,
  title = {Polymer {{Melts}} under {{Uniaxial Elongational Flow}}:  {{Stress}}−{{Optical Behavior}} from {{Experiments}} and {{Nonequilibrium Molecular Dynamics Computer Simulations}}},
  volume = {30},
  issn = {0024-9297},
  url = {http://dx.doi.org/10.1021/ma960317c},
  doi = {10.1021/ma960317c},
  shorttitle = {Polymer {{Melts}} under {{Uniaxial Elongational Flow}}},
  abstract = {Tensile stress and birefringence in both real and model amorphous polymer melts have been measured during constant rate uniaxial elongational flow. We focus on investigations where deviations from the linear stress?optical behavior are pronounced. A rate-dependent contribution to the stress which is not directly related to the intramolecular conformations (?stress offset?) is detected for both types of macromolecular fluids. Independent of the flow history, during relaxation a linear stress?optical behavior is revealed. Nonequilibrium molecular dynamics (NEMD) computer simulations on the multibead anharmonic spring model are shown to provide insight into the molecular mechanisms underlying the viscoelastic behavior:? during relaxation the intermolecular interactions become dominant in correlation with linear stress?optical behavior; the stress offset is shown to be very similar to the stress arising in the corresponding simple fluid; the total stress can well be approximated by a sum of three parts which are based on single-particle and single-link distribution functions only; the yield point behavior at high elongation rates reflects the transition from affine to nonaffine motion of bonds and is understood without reference to strong inhomogeneities resulting from local plastic strain production {[}the chemical structure does not influence the qualitative behavior]; distinct microscopic stress contributions under elongation and subsequent relaxation such as inter- and intramolecular, attractive and repulsive, kinetic and potential contributions are resolved.},
  timestamp = {2016-02-04T06:21:08Z},
  number = {3},
  journaltitle = {Macromolecules},
  shortjournal = {Macromolecules},
  author = {Kröger, M. and Luap, C. and Muller, R.},
  urldate = {2016-02-04},
  date = {1997-02-01},
  pages = {526--539},
  file = {ACS Full Text Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/57BIMUKE/ma960317c.html:}
}

