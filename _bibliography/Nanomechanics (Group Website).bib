@article{gaire_mechanical_2008,
  title = {Mechanical properties of porous methyl silsesquioxane and nanoclustering silica films using atomic force microscope},
  volume = {17},
  issn = {1380-2224, 1573-4854},
  url = {http://link.springer.com.libproxy.rpi.edu/article/10.1007/s10934-008-9259-y},
  doi = {10.1007/s10934-008-9259-y},
  abstract = {Mechanical properties of porous methyl silsesquioxane samples with dielectric constant 2.4 and 2.0 and a recently developed nanoclustering silica film samples with dielectric constants 2.3 and 2.0 were evaluated using an atomic force microscope based nanoindentation. It was found that the Young’s modulus and the hardness decrease while the fracture toughness increases with a decrease in the dielectric constant in the same type of material. Moreover, the Young’s modulus and the hardness of the nanoclustering silica films were observed to be at least twice and fracture toughness values {\textasciitilde}1.3–1.5 higher than those for methyl silsesquioxane films with similar dielectric constants. The high resolution topographic imaging capability of atomic force microscope was shown to be particularly useful in the measurement of cracks generated by the ultra-low indentation loads, and the evaluation of the fracture toughness of the nanoscale volumes of materials.},
  timestamp = {2016-02-07T04:03:33Z},
  langid = {english},
  number = {1},
  journaltitle = {Journal of Porous Materials},
  shortjournal = {J Porous Mater},
  author = {Gaire, C. and Ou, Y. and Arao, H. and Egami, M. and Nakashima, A. and Picu, Catalin R. and Wang, G.-C. and Lu, T.-M.},
  urldate = {2016-01-25},
  date = {2008-12-21},
  pages = {11--18},
  keywords = {Atomic Force Microscope,Catalysis,Characterization and Evaluation of Materials,Fracture toughness,Hardness,Methyl silsesquioxane,Nanoclustering silica,Physical Chemistry,Young’s modulus},
  file = {Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/CRM62JJK/s10934-008-9259-y.html:;Full Text PDF:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/ECBV3XD3/Gaire et al. - 2008 - Mechanical properties of porous methyl silsesquiox.pdf:application/pdf}
