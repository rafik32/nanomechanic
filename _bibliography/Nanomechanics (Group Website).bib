  urldate = {2016-01-25},
  date = {2006-01-03},
  pages = {231--238},
  keywords = {active materials,nanopumps,Nanostructures,NEMS},
  file = {Snapshot:/home/mersoj/.zotero/zotero/o1ifksm7.default/zotero/storage/HXAR92IT/231.html:}
}

@article{karabacak_stress_2004,
