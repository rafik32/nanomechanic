  issn = {0021-8979, 1089-7550},
  url = {http://scitation.aip.org.libproxy.rpi.edu/content/aip/journal/jap/96/10/10.1063/1.1803106},
  doi = {10.1063/1.1803106},
  abstract = {The residual stress in thin films is a major limiting factor for obtaining high quality films. We present a strategy for stress reduction in sputter depositedfilms by using a nanostructured compliant layer obtained by the oblique angle deposition technique, sandwiched between the film and the substrate. The technique is all in situ, does not require any lithography steps, and the nanostructured layer is made from the same material as the depositedthin film. By using this approach we were able to reduce stress values by approximately one order of magnitude in sputter depositedtungstenfilms. These lower stress thin films also exhibit stronger adhesion to the substrate, which retards delamination buckling. This technique allows the growth of much thicker films and has enhanced structural stability. A model is developed to explain the stress relief mechanism and the stronger adhesion associated with the presence of the nanostructured compliant layer.},
